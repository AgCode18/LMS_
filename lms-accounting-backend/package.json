{
  "name": "lms-accounting-engine",
  "version": "1.0.0",
  "description": "Accounting Engine module for AZZUNIQUE Loan Management Software",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "seed:coa": "node prisma/seedCoa.js",
    "seed:demo": "node prisma/seedDemo.js",
    "seed": "npm run seed:coa && npm run seed:demo"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/adapter-planetscale": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "pdfkit": "^0.19.1",
    "undici": "^8.7.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "nodemon": "^3.1.4",
    "prisma": "^7.8.0"
  }
}
